# Where the Humeo backend lives. The matcha-moments app calls
# `${NEXT_PUBLIC_HUMEO_API_URL}/api/public/reviews/*` for campaign data,
# submission, and status polling.
#
# Local dev: point at your local Humeo dev server.
# Staging:   https://staging.humeo.app  (or wherever your staging is)
# Prod:      https://humeo.app
#
# Note: humeo.app must allow CORS from this app's domain. The /api/public/reviews/*
# endpoints are designed to be called from the browser, but verify the allow-list
# includes matcha.humeo.app (or whatever domain you deploy this app to).
NEXT_PUBLIC_HUMEO_API_URL=https://humeo.app
